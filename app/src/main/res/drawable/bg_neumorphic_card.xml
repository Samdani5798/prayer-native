<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:left="2dp" android:top="3dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/shadow_dark" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    <item android:right="2dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/shadow_light" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/surface_elevated" />
            <corners android:radius="22dp" />
        </shape>
    </item>
</layer-list>
