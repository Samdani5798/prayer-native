<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavCard" />

    <LinearLayout
        android:id="@+id/bottomNavCard"
        android:layout_width="0dp"
        android:layout_height="76dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_neumorphic_card"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:id="@+id/navTracker"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackgroundBorderless">
            <ImageView
                android:id="@+id/iconTracker"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_tracker"
                android:contentDescription="@string/nav_tracker" />
            <TextView
                android:id="@+id/labelTracker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_tracker"
                style="@style/BottomNavLabel"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navQibla"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackgroundBorderless">
            <ImageView
                android:id="@+id/iconQibla"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_compass"
                android:contentDescription="@string/nav_qibla" />
            <TextView
                android:id="@+id/labelQibla"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_qibla"
                style="@style/BottomNavLabel"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1.1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_nav_home_pill">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_mosque"
                app:tint="@color/white"
                android:contentDescription="@string/nav_home" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_home"
                style="@style/BottomNavLabel"
                android:textColor="@color/white"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navCalendar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackgroundBorderless">
            <ImageView
                android:id="@+id/iconCalendar"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_calendar"
                android:contentDescription="@string/nav_calendar" />
            <TextView
                android:id="@+id/labelCalendar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_calendar"
                style="@style/BottomNavLabel"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navSettings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackgroundBorderless">
            <ImageView
                android:id="@+id/iconSettings"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_settings"
                android:contentDescription="@string/nav_settings" />
            <TextView
                android:id="@+id/labelSettings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_settings"
                style="@style/BottomNavLabel"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
